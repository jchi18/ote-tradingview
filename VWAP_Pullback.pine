//@version=6
// VWAP Pullback — A+ Limit Scanner
// Backtest-confirmed primary strategy (BACKTEST_RESULTS.md Rounds 7–8):
//   dual-EMA HTF trend filter -> in an uptrend rest a BUY-LIMIT at session VWAP,
//   in a downtrend a SELL-LIMIT at VWAP. Stop 0.5xATR beyond, target RR 1.5–2.0,
//   NY-AM window, ~1 trade/session. PF ~2.6 bull / ~2.8 bear on QQQ->NQ proxy.
// This is an INDICATOR: it marks the level, stop, target and position size.
// You place the resting limit order yourself, then walk away. No market orders.
indicator("VWAP Pullback — A+ Limit Scanner", "VWAP Pull", overlay = true,
     max_lines_count = 500, max_labels_count = 500)

// ───────────────────────── inputs ─────────────────────────
grpS = "Setup"
htfRes     = input.timeframe("60",  "HTF for trend bias",      group = grpS, tooltip = "Higher timeframe the EMA-cross bias is read from. 60 = 1H.")
emaFastLen = input.int(50,  "HTF fast EMA",  minval = 1,        group = grpS)
emaSlowLen = input.int(100, "HTF slow EMA",  minval = 1,        group = grpS, tooltip = "Bias is BULL when fast EMA > slow EMA, BEAR when fast < slow. Backtest 'dual' filter.")
sessTimes  = input.session("0930-1100", "Entry window (killzone)", group = grpS)
sessTz     = input.string("America/New_York", "Session timezone", group = grpS)

grpW = "VWAP anchor"
vwapSess = input.session("0930-1600", "VWAP session (anchor + accumulate)", group = grpW, tooltip = "VWAP RESETS at the start of this session and only accumulates bars inside it. Default = RTH 09:30–16:00 ET, which is what the strategy was backtested on. This is why it can differ from TradingView's built-in VWAP, which on a futures chart anchors to the 18:00 Globex open and includes overnight volume.")
oncePerDay = input.bool(true, "Only the first setup per session", group = grpS, tooltip = "Matches the ~1 trade/session discipline. Suppresses later same-day signals.")

grpR = "Risk / Targets"
atrLen   = input.int(14,   "ATR length",     minval = 1,      group = grpR)
stopMult = input.float(0.5,"Stop = ATR ×",   minval = 0.1, step = 0.1, group = grpR, tooltip = "Backtest sweet spot 0.4–0.5. A full-ATR stop breaks the edge — keep it tight.")
rr       = input.float(2.0,"Target R:R",     minval = 0.5, step = 0.1, group = grpR, tooltip = "1.5–2.0 tested best. Bears can favor 1.5.")

grpP = "Position sizing"
acct     = input.float(50000, "Account size ($)",        minval = 0, group = grpP)
riskPct  = input.float(1.0,   "Risk per trade (%)",      minval = 0.1, step = 0.1, group = grpP)
pointVal = input.float(2.0,   "$ per point (MNQ = 2)",   minval = 0.01, group = grpP, tooltip = "MNQ = $2/pt, NQ = $20/pt, MES = $5, ES = $50.")

grpV = "Display"
showLevels = input.bool(true, "Entry / stop / target lines", group = grpV)
showPanel  = input.bool(true, "Info panel",                  group = grpV)
showVwap   = input.bool(true, "VWAP line",                   group = grpV)

grpVP = "Volume levels (context only)"
showVP     = input.bool(false, "Volume POC + high-volume zones", group = grpVP, tooltip = "CONTEXT ONLY — these do NOT change the entry, stop, or target. Approximate volume profile over the lookback: the fuchsia POC is the most-traded price, gray dotted lines are other high-volume nodes. They act as magnets / support-resistance to be aware of around your VWAP limit. Backtested (Round 9): trading these directly has no edge — use them as awareness, not signals.")
vpLookback = input.int(120, "Lookback (bars)",                  minval = 10, maxval = 1000, group = grpVP)
vpBins     = input.int(24,  "Price bins (resolution)",          minval = 5,  maxval = 100,  group = grpVP)
vpZones    = input.int(3,   "High-volume zones (incl. POC)",    minval = 1,  maxval = 6,    group = grpVP)

// ───────────────────────── core calcs ─────────────────────────
// VWAP anchored to the RTH session (what the strategy was backtested on), computed
// manually so it resets at 09:30 ET and ignores overnight volume — unlike ta.vwap,
// which on a futures chart anchors to the 18:00 Globex open.
inVwapSess = not na(time(timeframe.period, vwapSess, sessTz))
newVwap    = inVwapSess and not inVwapSess[1]
var float cumPV = 0.0
var float cumV  = 0.0
var float cumTP = 0.0
var int   cumN  = 0
if newVwap
    cumPV := 0.0
    cumV  := 0.0
    cumTP := 0.0
    cumN  := 0
if inVwapSess
    v = na(volume) ? 0.0 : volume
    cumPV += hlc3 * v
    cumV  += v
    cumTP += hlc3
    cumN  += 1
vwap = cumV > 0 ? cumPV / cumV : (cumN > 0 ? cumTP / cumN : hlc3)   // volume VWAP; TWAP fallback if the symbol has no volume
atr  = ta.atr(atrLen)

emaFast = request.security(syminfo.tickerid, htfRes, ta.ema(close, emaFastLen), barmerge.gaps_off, barmerge.lookahead_off)
emaSlow = request.security(syminfo.tickerid, htfRes, ta.ema(close, emaSlowLen), barmerge.gaps_off, barmerge.lookahead_off)
biasBull = emaFast > emaSlow
biasBear = emaFast < emaSlow

inWin = not na(time(timeframe.period, sessTimes, sessTz))
newSession = inWin and not inWin[1]
var bool tradedToday = false
if newSession
    tradedToday := false

// setup = trend agrees AND price is on the far side of VWAP (a pullback to the
// mean is still pending). The resting limit waits at VWAP for price to come back.
longCond  = inWin and biasBull and close > vwap
shortCond = inWin and biasBear and close < vwap

// entry / stop / target
entry     = vwap
longStop  = vwap - stopMult * atr
longTgt   = entry + rr * (entry - longStop)
shortStop = vwap + stopMult * atr
shortTgt  = entry - rr * (shortStop - entry)

// position size (contracts) from fixed-% risk
riskDollars = acct * riskPct / 100.0
longRiskPts = entry - longStop
shortRiskPts= shortStop - entry
longQty  = longRiskPts  > 0 ? math.floor(riskDollars / (longRiskPts  * pointVal)) : 0
shortQty = shortRiskPts > 0 ? math.floor(riskDollars / (shortRiskPts * pointVal)) : 0

// fresh trigger = first bar the condition turns true (this session)
freshLong  = longCond  and not longCond[1]  and (not oncePerDay or not tradedToday)
freshShort = shortCond and not shortCond[1] and (not oncePerDay or not tradedToday)
if freshLong or freshShort
    tradedToday := true

setupActive = (longCond or shortCond) and (not oncePerDay or freshLong or freshShort or tradedToday)
isLong = longCond and biasBull

// ───────────────────────── plots ─────────────────────────
plot(showVwap ? vwap : na, "VWAP (live limit level)", color.new(color.blue, 0), 2)

// fresh-setup markers
plotshape(freshLong,  "Fresh LONG",  shape.triangleup,   location.belowbar, color.new(color.teal, 0), size = size.small)
plotshape(freshShort, "Fresh SHORT", shape.triangledown, location.abovebar, color.new(color.maroon, 0), size = size.small)

// ── Order levels ── three labeled horizontal lines that RIDE the live VWAP while a
// setup is active and unfilled, so the orange ENTRY line always sits exactly on the
// blue VWAP. Place your resting limit at the orange price; as VWAP drifts, the level
// updates with it. The lines disappear once price reaches VWAP (your fill) or the
// window closes. Orange = limit entry, red dashed = stop, green dashed = target.
var line  lnE = na
var line  lnS = na
var line  lnT = na
var label lbE = na
var label lbS = na
var label lbT = na
var int   startBar = 0

showNow = setupActive and showLevels
if showNow
    eY   = entry
    sY   = isLong ? longStop : shortStop
    tY   = isLong ? longTgt  : shortTgt
    qty  = isLong ? longQty  : shortQty
    side = isLong ? "BUY LIMIT" : "SELL LIMIT"
    if na(lnE)
        startBar := bar_index
        lnE := line.new(startBar, eY, bar_index, eY, color = color.orange, width = 2, extend = extend.right)
        lnS := line.new(startBar, sY, bar_index, sY, color = color.red,   width = 1, style = line.style_dashed, extend = extend.right)
        lnT := line.new(startBar, tY, bar_index, tY, color = color.green, width = 1, style = line.style_dashed, extend = extend.right)
        lbE := label.new(bar_index, eY, "", style = label.style_label_left, color = color.new(color.orange, 0), textcolor = color.white, size = size.small)
        lbS := label.new(bar_index, sY, "", style = label.style_label_left, color = color.new(color.red, 0),   textcolor = color.white, size = size.small)
        lbT := label.new(bar_index, tY, "", style = label.style_label_left, color = color.new(color.green, 0), textcolor = color.white, size = size.small)
    line.set_xy1(lnE, startBar, eY)
    line.set_xy2(lnE, bar_index, eY)
    line.set_xy1(lnS, startBar, sY)
    line.set_xy2(lnS, bar_index, sY)
    line.set_xy1(lnT, startBar, tY)
    line.set_xy2(lnT, bar_index, tY)
    label.set_xy(lbE, bar_index, eY)
    label.set_text(lbE, side + "  " + str.tostring(eY, format.mintick) + "   (" + str.tostring(qty) + " ct)")
    label.set_xy(lbS, bar_index, sY)
    label.set_text(lbS, "SL  " + str.tostring(sY, format.mintick))
    label.set_xy(lbT, bar_index, tY)
    label.set_text(lbT, "TP  " + str.tostring(tY, format.mintick))
else
    if not na(lnE)
        line.delete(lnE)
        line.delete(lnS)
        line.delete(lnT)
        label.delete(lbE)
        label.delete(lbS)
        label.delete(lbT)
        lnE := na
        lnS := na
        lnT := na
        lbE := na
        lbS := na
        lbT := na

// ───────────────────────── info panel ─────────────────────────
var table panel = table.new(position.top_right, 2, 7, border_width = 1)
f_row(tbl, r, k, v, col) =>
    table.cell(tbl, 0, r, k, text_color = color.gray, text_size = size.small, text_halign = text.align_left)
    table.cell(tbl, 1, r, v, text_color = col, text_size = size.small, text_halign = text.align_right)
if showPanel and barstate.islast
    biasTxt = biasBull ? "BULL ▲" : biasBear ? "BEAR ▼" : "flat"
    biasCol = biasBull ? color.teal : biasBear ? color.maroon : color.gray
    winTxt  = inWin ? "OPEN" : "closed"
    sActive = setupActive
    sTxt = not sActive ? "— none —" : isLong ? "LONG ready" : "SHORT ready"
    sCol = not sActive ? color.gray : isLong ? color.teal : color.maroon
    e = isLong ? entry : entry
    s = isLong ? longStop : shortStop
    t = isLong ? longTgt : shortTgt
    q = isLong ? longQty : shortQty
    f_row(panel, 0, "HTF bias",  biasTxt, biasCol)
    f_row(panel, 1, "Window",    winTxt, inWin ? color.teal : color.gray)
    f_row(panel, 2, "Setup",     sTxt, sCol)
    f_row(panel, 3, "Limit @",   sActive ? str.tostring(e, format.mintick) : "—", color.orange)
    f_row(panel, 4, "Stop",      sActive ? str.tostring(s, format.mintick) : "—", color.red)
    f_row(panel, 5, "Target",    sActive ? str.tostring(t, format.mintick) : "—", color.green)
    f_row(panel, 6, "Size (ct)", sActive ? str.tostring(q) : "—", color.white)

// ── Volume levels (CONTEXT ONLY — does not affect entry/stop/target) ──
// Pine has no native volume-by-price, so we approximate it: split the recent price
// range into bins, add each bar's volume to the bin its typical price falls in, then
// mark the busiest bins. Busiest of all = POC (fuchsia). The rest = high-volume nodes
// (gray dotted). Drawn once on the last bar and refreshed as new bars arrive.
vpHi = ta.highest(high, vpLookback)
vpLo = ta.lowest(low,  vpLookback)
var array<line>  vpLines  = array.new<line>()
var array<label> vpLabels = array.new<label>()

if showVP and barstate.islast and vpHi > vpLo
    for i = 0 to array.size(vpLines) - 1
        line.delete(array.get(vpLines, i))
    for i = 0 to array.size(vpLabels) - 1
        label.delete(array.get(vpLabels, i))
    array.clear(vpLines)
    array.clear(vpLabels)
    binSize = (vpHi - vpLo) / vpBins
    vols = array.new<float>(vpBins, 0.0)
    for k = 0 to vpLookback - 1
        if not na(high[k]) and not na(low[k])
            tp   = (high[k] + low[k] + close[k]) / 3.0
            bvol = na(volume[k]) ? 0.0 : volume[k]
            bi   = int(math.floor((tp - vpLo) / binSize))
            bi   := math.max(0, math.min(vpBins - 1, bi))
            array.set(vols, bi, array.get(vols, bi) + bvol)
    leftX = bar_index - vpLookback
    drawn = 0
    while drawn < vpZones
        bestIdx = -1
        bestVol = 0.0
        for b = 0 to vpBins - 1
            cur = array.get(vols, b)
            if cur > bestVol
                bestVol := cur
                bestIdx := b
        if bestIdx < 0
            break
        price = vpLo + (bestIdx + 0.5) * binSize
        isPoc = drawn == 0
        col   = isPoc ? color.fuchsia : color.gray
        ln = line.new(leftX, price, bar_index, price, color = color.new(col, isPoc ? 0 : 30), width = 1, style = isPoc ? line.style_solid : line.style_dotted, extend = extend.right)
        lb = label.new(bar_index, price, (isPoc ? "POC " : "HVN ") + str.tostring(price, format.mintick), style = label.style_label_left, color = color.new(col, isPoc ? 0 : 20), textcolor = color.white, size = size.tiny)
        array.push(vpLines, ln)
        array.push(vpLabels, lb)
        array.set(vols, bestIdx, -1.0)
        drawn += 1

// ───────────────────────── alerts ─────────────────────────
alertcondition(freshLong,  "VWAP long limit",  "VWAP Pullback: BULL bias — rest a BUY-LIMIT at session VWAP. Stop 0.5xATR below, target RR.")
alertcondition(freshShort, "VWAP short limit", "VWAP Pullback: BEAR bias — rest a SELL-LIMIT at session VWAP. Stop 0.5xATR above, target RR.")
alertcondition(freshLong or freshShort, "VWAP setup (either)", "VWAP Pullback A+ setup formed — check the chart and place your resting limit.")
