//@version=6
// VWAP Pullback — A+ Limit Scanner  (clean rebuild)
// Backtest-confirmed primary strategy (BACKTEST_RESULTS.md Rounds 7–10):
//   higher-timeframe EMA trend filter -> in an uptrend BUY the pullback to VWAP,
//   in a downtrend SELL the pullback to VWAP. Stop 0.5xATR beyond, target RR 1.5–2.0.
// This rebuild: clear BUY/SELL arrows (the entry signal), no bottom notes box, and a
// VWAP that resets each trading day by default so it looks like the standard VWAP on
// any symbol (incl. 24h crypto). Stop/target lines show only while a trade is live.
indicator("VWAP Pullback — A+ Limit Scanner", "VWAP Pull", overlay = true,
     max_lines_count = 50, max_labels_count = 50)

// ───────────────────────── inputs ─────────────────────────
grpS = "Trend bias (higher timeframe)"
htfRes     = input.timeframe("60", "Bias timeframe", group = grpS, tooltip = "Timeframe the EMA trend is read from. 60 = 1H.")
emaFastLen = input.int(50,  "Fast EMA", minval = 1, group = grpS)
emaSlowLen = input.int(100, "Slow EMA", minval = 1, group = grpS, tooltip = "Bias is BULL when fast EMA > slow EMA, BEAR when fast < slow.")

grpW = "VWAP"
vwapReset = input.string("Each day", "VWAP resets", options = ["Each day", "Regular session (RTH)"], group = grpW, tooltip = "Each day = resets at the start of every trading day — looks like the standard VWAP and works on any symbol, including 24h crypto. Regular session = resets 09:30 ET and only counts 09:30–16:00; this is the exact anchor the MNQ strategy was backtested on, but on a 24h chart it will look 'off'.")
rthSess   = input.session("0930-1600", "Regular session (for RTH mode)", group = grpW)
sessTz    = input.string("America/New_York", "Session timezone", group = grpW)

grpE = "Signals"
useWindow  = input.bool(false, "Only signal during a time window", group = grpE, tooltip = "OFF = signals allowed any time (good for crypto / 24h). ON = only inside the window below.")
winSess    = input.session("0930-1600", "Signal window", group = grpE)
oncePerDay = input.bool(true, "Max one signal per day", group = grpE, tooltip = "Matches the ~1 trade/session discipline.")

grpR = "Risk / targets"
atrLen   = input.int(14, "ATR length", minval = 1, group = grpR)
stopMult = input.float(0.5, "Stop = ATR ×", minval = 0.1, step = 0.1, group = grpR, tooltip = "Backtest sweet spot 0.4–0.5. Keep it tight.")
rr       = input.float(2.0, "Target R:R", minval = 0.5, step = 0.1, group = grpR)

grpP = "Position size"
acct     = input.float(50000, "Account ($)", minval = 0, group = grpP)
riskPct  = input.float(1.0, "Risk per trade (%)", minval = 0.1, step = 0.1, group = grpP)
pointVal = input.float(2.0, "$ per point (MNQ=2, NQ=20, MES=5, ES=50)", minval = 0.01, group = grpP)

grpV = "Show"
showVwap    = input.bool(true, "VWAP line", group = grpV)
showSignals = input.bool(true, "Entry signals (BUY / SELL arrows)", group = grpV)
showLevels  = input.bool(true, "Stop / target lines (only while a trade is live)", group = grpV)
showPanel   = input.bool(true, "Info panel (top-right)", group = grpV)

// ───────────────────────── VWAP ─────────────────────────
// Reset either each day (standard look) or at the RTH open (backtested anchor).
useRth      = vwapReset == "Regular session (RTH)"
inRth       = not na(time(timeframe.period, rthSess, sessTz))
newDay      = timeframe.change("D")
anchorReset = useRth ? (inRth and not inRth[1]) : newDay
accumulate  = useRth ? inRth : true

var float cumPV = 0.0
var float cumV  = 0.0
var float cumTP = 0.0
var int   cumN  = 0
if anchorReset
    cumPV := 0.0
    cumV  := 0.0
    cumTP := 0.0
    cumN  := 0
if accumulate
    vv = na(volume) ? 0.0 : volume
    cumPV += hlc3 * vv
    cumV  += vv
    cumTP += hlc3
    cumN  += 1
vwap = cumV > 0 ? cumPV / cumV : (cumN > 0 ? cumTP / cumN : hlc3)   // volume VWAP; price-mean fallback if no volume
atr  = ta.atr(atrLen)

// ───────────────────────── trend bias ─────────────────────────
emaFast = request.security(syminfo.tickerid, htfRes, ta.ema(close, emaFastLen), barmerge.gaps_off, barmerge.lookahead_off)
emaSlow = request.security(syminfo.tickerid, htfRes, ta.ema(close, emaSlowLen), barmerge.gaps_off, barmerge.lookahead_off)
biasBull = emaFast > emaSlow
biasBear = emaFast < emaSlow

// ───────────────────────── entry signals ─────────────────────────
// The trade is a pullback to VWAP in the trend direction: in an uptrend, price is
// above VWAP and dips back to touch it (your buy); mirror for downtrend.
inWin = useWindow ? not na(time(timeframe.period, winSess, sessTz)) : true
var bool tradedToday = false
if newDay
    tradedToday := false

canTrade  = not oncePerDay or not tradedToday
longRaw   = biasBull and inWin and low  <= vwap and high >= vwap and canTrade   // dipped to VWAP in uptrend
shortRaw  = biasBear and inWin and high >= vwap and low  <= vwap and canTrade   // popped to VWAP in downtrend
buySig    = longRaw  and not longRaw[1]  and barstate.isconfirmed
sellSig   = shortRaw and not shortRaw[1] and barstate.isconfirmed
if buySig or sellSig
    tradedToday := true

// ───────────────────────── live trade state ─────────────────────────
// Fix entry/stop/target when the arrow prints; clear when stop or target is hit.
var bool  tradeOn  = false
var int   tradeDir = 0
var float tEntry   = na
var float tStop    = na
var float tTgt     = na
var int   tQty     = 0

riskDollars = acct * riskPct / 100.0
if buySig
    tradeOn  := true
    tradeDir := 1
    tEntry   := vwap
    tStop    := vwap - stopMult * atr
    tTgt     := tEntry + rr * (tEntry - tStop)
    rp = tEntry - tStop
    tQty := rp > 0 ? math.floor(riskDollars / (rp * pointVal)) : 0
if sellSig
    tradeOn  := true
    tradeDir := -1
    tEntry   := vwap
    tStop    := vwap + stopMult * atr
    tTgt     := tEntry - rr * (tStop - tEntry)
    rp = tStop - tEntry
    tQty := rp > 0 ? math.floor(riskDollars / (rp * pointVal)) : 0
if tradeOn and not (buySig or sellSig)
    if tradeDir == 1 and (low <= tStop or high >= tTgt)
        tradeOn := false
    if tradeDir == -1 and (high >= tStop or low <= tTgt)
        tradeOn := false

// ───────────────────────── plots ─────────────────────────
plot(showVwap ? vwap : na, "VWAP", color.new(color.blue, 0), 2)

plotshape(showSignals and buySig,  "BUY",  shape.labelup,   location.belowbar, color.new(color.teal, 0),  text = "BUY",  textcolor = color.white, size = size.small)
plotshape(showSignals and sellSig, "SELL", shape.labeldown, location.abovebar, color.new(color.red, 0),   text = "SELL", textcolor = color.white, size = size.small)

// ── stop / target lines, drawn only while a trade is live ──
// Left edge trails the current bar (stays close to "now") so it can never exceed
// Pine's bar-index distance limit. Lines disappear the moment the trade closes.
var line  slLine = na
var line  tpLine = na
var label slLab  = na
var label tpLab  = na
if showLevels and tradeOn
    leftX = math.max(0, bar_index - 60)
    if na(slLine)
        slLine := line.new(leftX, tStop, bar_index, tStop, color = color.red,   width = 1, style = line.style_dashed, extend = extend.right)
        tpLine := line.new(leftX, tTgt,  bar_index, tTgt,  color = color.green, width = 1, style = line.style_dashed, extend = extend.right)
        slLab  := label.new(bar_index, tStop, "", style = label.style_label_left, color = color.new(color.red, 0),   textcolor = color.white, size = size.small)
        tpLab  := label.new(bar_index, tTgt,  "", style = label.style_label_left, color = color.new(color.green, 0), textcolor = color.white, size = size.small)
    line.set_xy1(slLine, leftX, tStop)
    line.set_xy2(slLine, bar_index, tStop)
    line.set_xy1(tpLine, leftX, tTgt)
    line.set_xy2(tpLine, bar_index, tTgt)
    label.set_xy(slLab, bar_index, tStop)
    label.set_text(slLab, "SL  " + str.tostring(tStop, format.mintick))
    label.set_xy(tpLab, bar_index, tTgt)
    label.set_text(tpLab, "TP  " + str.tostring(tTgt, format.mintick))
else
    if not na(slLine)
        line.delete(slLine)
        line.delete(tpLine)
        label.delete(slLab)
        label.delete(tpLab)
        slLine := na
        tpLine := na
        slLab  := na
        tpLab  := na

// ───────────────────────── info panel ─────────────────────────
var table panel = table.new(position.top_right, 2, 6, border_width = 1)
f_row(r, k, v, col) =>
    table.cell(panel, 0, r, k, text_color = color.gray,  text_size = size.small, text_halign = text.align_left)
    table.cell(panel, 1, r, v, text_color = col,         text_size = size.small, text_halign = text.align_right)
if showPanel and barstate.islast
    biasTxt = biasBull ? "BULL ▲" : biasBear ? "BEAR ▼" : "flat"
    biasCol = biasBull ? color.teal : biasBear ? color.maroon : color.gray
    tradeTxt = tradeOn ? (tradeDir == 1 ? "LONG live" : "SHORT live") : "— none —"
    tradeCol = tradeOn ? (tradeDir == 1 ? color.teal : color.maroon) : color.gray
    f_row(0, "HTF bias", biasTxt, biasCol)
    f_row(1, "Trade",    tradeTxt, tradeCol)
    f_row(2, "Entry",    tradeOn ? str.tostring(tEntry, format.mintick) : "—", color.orange)
    f_row(3, "Stop",     tradeOn ? str.tostring(tStop,  format.mintick) : "—", color.red)
    f_row(4, "Target",   tradeOn ? str.tostring(tTgt,   format.mintick) : "—", color.green)
    f_row(5, "Size (ct)",tradeOn ? str.tostring(tQty) : "—", color.white)

// ───────────────────────── alerts ─────────────────────────
alertcondition(buySig,  "BUY signal",  "VWAP Pullback BUY: uptrend pullback to VWAP. Buy, stop 0.5xATR below, target RR.")
alertcondition(sellSig, "SELL signal", "VWAP Pullback SELL: downtrend pullback to VWAP. Sell, stop 0.5xATR above, target RR.")
alertcondition(buySig or sellSig, "Any signal", "VWAP Pullback signal — check the chart.")
