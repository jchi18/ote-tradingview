//@version=6
// VWAP Pullback — A+ Dip Scanner
//   The edge is MEAN-REVERSION to VWAP, not chasing breakouts (momentum breakouts
//   backtest at PF~1.0; this dip-buy backtests PF 2.5–2.8, maxDD ~5R on MNQ proxy).
//   Logic: higher-timeframe EMA trend filter -> in an UPTREND, when price is above
//   VWAP, you wait for a PULLBACK down to the VWAP line and BUY the bounce ("BUY DIP").
//   In a DOWNTREND you wait for a rally up to VWAP and SELL it ("SELL RIP").
//   The arrow prints AT the VWAP line on the pullback — so you're buying the dip, not
//   the top. Entry = VWAP, stop 0.5xATR beyond it, target RR 2.0.
// Clean: clear BUY DIP / SELL RIP arrows, no notes box, daily-anchored VWAP (looks
// standard on any symbol incl. crypto). Stop/target lines show only while a trade is live.
indicator("VWAP Pullback — A+ Dip Scanner", "VWAP Pull", overlay = true,
     max_lines_count = 50, max_labels_count = 50)

// ───────────────────────── inputs ─────────────────────────
grpS = "Trend bias (higher timeframe)"
htfRes     = input.timeframe("60", "Bias timeframe", group = grpS, tooltip = "Timeframe the EMA trend is read from. 60 = 1H.")
emaFastLen = input.int(50,  "Fast EMA", minval = 1, group = grpS)
emaSlowLen = input.int(100, "Slow EMA", minval = 1, group = grpS, tooltip = "Bias is BULL when fast EMA > slow EMA, BEAR when fast < slow.")

grpW = "VWAP"
vwapReset = input.string("Each day", "VWAP resets", options = ["Each day", "Regular session (RTH)"], group = grpW, tooltip = "Each day = resets at the start of every trading day — looks like the standard VWAP and works on any symbol, including 24h crypto. Regular session = resets 09:30 ET and only counts 09:30–16:00; this is the exact anchor the MNQ strategy was backtested on, but on a 24h chart it will look 'off'.")
rthSess   = input.session("0930-1600", "Regular session (for RTH mode)", group = grpW)
sessTz    = input.string("America/New_York", "Session timezone", group = grpW)

grpE = "Signals (VWAP pullback / dip-buy)"
slopeLen   = input.int(5, "VWAP slope length (bars)", minval = 1, group = grpE, tooltip = "VWAP must be rising over this many bars to allow dip-buys (falling for rip-sells) — keeps you with the intraday drift.")
useWindow  = input.bool(false, "Only signal during a time window", group = grpE, tooltip = "OFF = signals allowed any time (good for crypto / 24h). ON = only inside the window below. The MNQ edge backtests strongest 09:30–11:00 ET — turn this on and set the window for that.")
winSess    = input.session("0930-1100", "Signal window", group = grpE)
oncePerDay = input.bool(true, "Max one trade per day", group = grpE, tooltip = "ON = at most one dip-buy/rip-sell per day (matches the backtest). OFF = take every pullback.")
stretchMin = input.float(1.0, "A+: min stretch from VWAP (ATR)", minval = 0, step = 0.1, group = grpE, tooltip = "A ★ A+ grade also needs price to have stretched at least this far from VWAP earlier in the session before pulling back — the highest-conviction dips (backtest: PF 3.3 in trends). ~1.0 is the sweet spot.")
onlyAplus  = input.bool(false, "Only show ★ A+ signals", group = grpE, tooltip = "ON = hide ordinary dips, show only A+ (strong stacked trend + stretched from VWAP). Fewer signals, highest conviction. Note: A+ is regime-tuned to trends — leave OFF to keep the full backtested edge.")

grpR = "Risk / targets"
atrLen   = input.int(14, "ATR length", minval = 1, group = grpR)
stopMult = input.float(0.5, "Stop = ATR ×", minval = 0.1, step = 0.1, group = grpR, tooltip = "Backtest sweet spot 0.4–0.5. Keep it tight.")
rr       = input.float(2.0, "Target R:R", minval = 0.5, step = 0.1, group = grpR)

grpP = "Position size"
acct     = input.float(50000, "Account ($)", minval = 0, group = grpP)
riskPct  = input.float(1.0, "Risk per trade (%)", minval = 0.1, step = 0.1, group = grpP)
pointVal = input.float(2.0, "$ per point (MNQ=2, NQ=20, MES=5, ES=50)", minval = 0.01, group = grpP)

grpV = "Show"
showVwap    = input.bool(true, "VWAP line", group = grpV)
showSignals = input.bool(true, "Entry signals (BUY / SELL arrows)", group = grpV)
showLevels  = input.bool(true, "Stop / target lines (only while a trade is live)", group = grpV)
showPanel   = input.bool(true, "Info panel (top-right)", group = grpV)

// ───────────────────────── VWAP ─────────────────────────
// Reset either each day (standard look) or at the RTH open (backtested anchor).
useRth      = vwapReset == "Regular session (RTH)"
inRth       = not na(time(timeframe.period, rthSess, sessTz))
newDay      = timeframe.change("D")
anchorReset = useRth ? (inRth and not inRth[1]) : newDay
accumulate  = useRth ? inRth : true

var float cumPV = 0.0
var float cumV  = 0.0
var float cumTP = 0.0
var int   cumN  = 0
if anchorReset
    cumPV := 0.0
    cumV  := 0.0
    cumTP := 0.0
    cumN  := 0
if accumulate
    vv = na(volume) ? 0.0 : volume
    cumPV += hlc3 * vv
    cumV  += vv
    cumTP += hlc3
    cumN  += 1
vwap = cumV > 0 ? cumPV / cumV : (cumN > 0 ? cumTP / cumN : hlc3)   // volume VWAP; price-mean fallback if no volume
atr  = ta.atr(atrLen)

// How far price stretched from VWAP this session (in ATRs) — used for A+ grading.
// A real reversion comes from an extension, not from chop hugging the line.
var float maxUpATR = 0.0
var float maxDnATR = 0.0
if anchorReset
    maxUpATR := 0.0
    maxDnATR := 0.0
stretchNow = atr > 0 ? (close - vwap) / atr : 0.0
maxUpATR := math.max(maxUpATR, stretchNow)
maxDnATR := math.max(maxDnATR, -stretchNow)

// ───────────────────────── trend bias ─────────────────────────
emaFast = request.security(syminfo.tickerid, htfRes, ta.ema(close, emaFastLen), barmerge.gaps_off, barmerge.lookahead_off)
emaSlow = request.security(syminfo.tickerid, htfRes, ta.ema(close, emaSlowLen), barmerge.gaps_off, barmerge.lookahead_off)
biasBull = emaFast > emaSlow
biasBear = emaFast < emaSlow

// ───────────────────────── entry signals (VWAP pullback / dip-buy) ─────────────────────────
// In an UPTREND with a rising VWAP, when price has been trading ABOVE VWAP, BUY the
// PULLBACK: the bar dips down to touch the VWAP line and closes back above it. You buy
// the dip at fair value, not the top. SELL mirror (rally up to VWAP in a downtrend).
inWin = useWindow ? not na(time(timeframe.period, winSess, sessTz)) : true
var bool tradedToday = false
if newDay
    tradedToday := false

slopeUp = vwap > vwap[slopeLen]
slopeDn = vwap < vwap[slopeLen]
// "armed" = the regime is right and we're waiting for a pullback to the line
armedLong  = biasBull and slopeUp and close > vwap and inWin
armedShort = biasBear and slopeDn and close < vwap and inWin
// trigger = the bar pulled back to VWAP and closed back on the trend side
dipToVwap  = low  <= vwap and close > vwap   // touched the line from above, held above
ripToVwap  = high >= vwap and close < vwap   // touched the line from below, held below
canTrade   = not oncePerDay or not tradedToday

buySig    = armedLong  and dipToVwap and canTrade and barstate.isconfirmed
sellSig   = armedShort and ripToVwap and canTrade and barstate.isconfirmed

// ── confidence grade: ★ A+ = strong stacked trend AND price was stretched from VWAP ──
strongUp = close > emaFast and emaFast > emaSlow and emaFast > emaFast[10]
strongDn = close < emaFast and emaFast < emaSlow and emaFast < emaFast[10]
aplusBuy  = buySig  and strongUp and maxUpATR >= stretchMin
aplusSell = sellSig and strongDn and maxDnATR >= stretchMin
// what actually prints / drives the trade, honoring the "only A+" toggle
showBuy  = buySig  and (not onlyAplus or aplusBuy)
showSell = sellSig and (not onlyAplus or aplusSell)
if showBuy or showSell
    tradedToday := true

// ───────────────────────── live trade state ─────────────────────────
// Fix entry/stop/target when the arrow prints; clear when stop or target is hit.
var bool  tradeOn  = false
var int   tradeDir = 0
var float tEntry   = na
var float tStop    = na
var float tTgt     = na
var int   tQty     = 0

// Entry is the VWAP line itself (where your limit fills on the pullback), stop 0.5xATR
// beyond it — exactly the levels the backtest used.
riskDollars = acct * riskPct / 100.0
if showBuy
    tradeOn  := true
    tradeDir := 1
    tEntry   := vwap
    tStop    := vwap - stopMult * atr
    tTgt     := tEntry + rr * (tEntry - tStop)
    rp = tEntry - tStop
    tQty := rp > 0 ? math.floor(riskDollars / (rp * pointVal)) : 0
if showSell
    tradeOn  := true
    tradeDir := -1
    tEntry   := vwap
    tStop    := vwap + stopMult * atr
    tTgt     := tEntry - rr * (tStop - tEntry)
    rp = tStop - tEntry
    tQty := rp > 0 ? math.floor(riskDollars / (rp * pointVal)) : 0
if tradeOn and not (showBuy or showSell)
    if tradeDir == 1 and (low <= tStop or high >= tTgt)
        tradeOn := false
    if tradeDir == -1 and (high >= tStop or low <= tTgt)
        tradeOn := false

// ───────────────────────── plots ─────────────────────────
plot(showVwap ? vwap : na, "VWAP", color.new(color.blue, 0), 2)

// ★ A+ = big, solid.  ordinary dip = small, faded.  ("only A+" hides the faded ones.)
plotshape(showSignals and showBuy and aplusBuy,        "A+ BUY",   shape.labelup,   location.belowbar, color.new(color.teal, 0),  text = "★ BUY DIP", textcolor = color.white, size = size.normal)
plotshape(showSignals and showBuy and not aplusBuy,    "BUY DIP",  shape.labelup,   location.belowbar, color.new(color.teal, 45), text = "buy dip",   textcolor = color.white, size = size.tiny)
plotshape(showSignals and showSell and aplusSell,      "A+ SELL",  shape.labeldown, location.abovebar, color.new(color.red, 0),   text = "★ SELL RIP",textcolor = color.white, size = size.normal)
plotshape(showSignals and showSell and not aplusSell,  "SELL RIP", shape.labeldown, location.abovebar, color.new(color.red, 45),  text = "sell rip",  textcolor = color.white, size = size.tiny)

// ── stop / target lines, drawn only while a trade is live ──
// Left edge trails the current bar (stays close to "now") so it can never exceed
// Pine's bar-index distance limit. Lines disappear the moment the trade closes.
var line  slLine = na
var line  tpLine = na
var label slLab  = na
var label tpLab  = na
if showLevels and tradeOn
    leftX = math.max(0, bar_index - 60)
    if na(slLine)
        slLine := line.new(leftX, tStop, bar_index, tStop, color = color.red,   width = 1, style = line.style_dashed, extend = extend.right)
        tpLine := line.new(leftX, tTgt,  bar_index, tTgt,  color = color.green, width = 1, style = line.style_dashed, extend = extend.right)
        slLab  := label.new(bar_index, tStop, "", style = label.style_label_left, color = color.new(color.red, 0),   textcolor = color.white, size = size.small)
        tpLab  := label.new(bar_index, tTgt,  "", style = label.style_label_left, color = color.new(color.green, 0), textcolor = color.white, size = size.small)
    line.set_xy1(slLine, leftX, tStop)
    line.set_xy2(slLine, bar_index, tStop)
    line.set_xy1(tpLine, leftX, tTgt)
    line.set_xy2(tpLine, bar_index, tTgt)
    label.set_xy(slLab, bar_index, tStop)
    label.set_text(slLab, "SL  " + str.tostring(tStop, format.mintick))
    label.set_xy(tpLab, bar_index, tTgt)
    label.set_text(tpLab, "TP  " + str.tostring(tTgt, format.mintick))
else
    if not na(slLine)
        line.delete(slLine)
        line.delete(tpLine)
        label.delete(slLab)
        label.delete(tpLab)
        slLine := na
        tpLine := na
        slLab  := na
        tpLab  := na

// ───────────────────────── info panel ─────────────────────────
var table panel = table.new(position.top_right, 2, 7, border_width = 1)
f_row(r, k, v, col) =>
    table.cell(panel, 0, r, k, text_color = color.gray,  text_size = size.small, text_halign = text.align_left)
    table.cell(panel, 1, r, v, text_color = col,         text_size = size.small, text_halign = text.align_right)
if showPanel and barstate.islast
    biasTxt = biasBull ? "BULL ▲" : biasBear ? "BEAR ▼" : "flat"
    biasCol = biasBull ? color.teal : biasBear ? color.maroon : color.gray
    aReadyL = armedLong  and strongUp and maxUpATR >= stretchMin
    aReadyS = armedShort and strongDn and maxDnATR >= stretchMin
    setupTxt = armedLong ? (aReadyL ? "buy dip — ★ A+ ready" : "buy dip to VWAP") : armedShort ? (aReadyS ? "sell rip — ★ A+ ready" : "sell rip to VWAP") : "— wait —"
    setupCol = armedLong ? color.teal : armedShort ? color.maroon : color.gray
    tradeTxt = tradeOn ? (tradeDir == 1 ? "LONG live" : "SHORT live") : "— none —"
    tradeCol = tradeOn ? (tradeDir == 1 ? color.teal : color.maroon) : color.gray
    f_row(0, "HTF bias", biasTxt, biasCol)
    f_row(1, "Setup",    setupTxt, setupCol)
    f_row(2, "Trade",    tradeTxt, tradeCol)
    f_row(3, "Entry",    tradeOn ? str.tostring(tEntry, format.mintick) : "—", color.orange)
    f_row(4, "Stop",     tradeOn ? str.tostring(tStop,  format.mintick) : "—", color.red)
    f_row(5, "Target",   tradeOn ? str.tostring(tTgt,   format.mintick) : "—", color.green)
    f_row(6, "Size (ct)",tradeOn ? str.tostring(tQty) : "—", color.white)

// ───────────────────────── alerts ─────────────────────────
alertcondition(showBuy,  "BUY DIP signal",  "VWAP pullback BUY: uptrend, price dipped to VWAP and bounced. Entry VWAP, stop 0.5xATR below, target RR.")
alertcondition(showSell, "SELL RIP signal", "VWAP rally SELL: downtrend, price popped to VWAP and rejected. Entry VWAP, stop 0.5xATR above, target RR.")
alertcondition(aplusBuy,  "A+ BUY DIP",  "★ A+ VWAP pullback BUY: strong trend + stretched from VWAP. Highest conviction.")
alertcondition(aplusSell, "A+ SELL RIP", "★ A+ VWAP rally SELL: strong trend + stretched from VWAP. Highest conviction.")
alertcondition(showBuy or showSell, "Any signal", "VWAP pullback signal — check the chart.")
