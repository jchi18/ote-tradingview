//@version=6
// Swing OTE - MTF Swing Points
//   A clean, NON-REPAINTING multi-timeframe swing-point plotter. Detect swings on a chosen
//   structure timeframe and plot them onto any chart, so you can execute on a low-TF chart while
//   reading higher-timeframe structure and dropping your OWN OTE fib on the impulse legs.
//
//   TWO TIERS:
//     - MAJOR swings (bold)  = strong pivots -> the impulse-leg highs/lows you anchor an OTE to.
//     - MINOR swings (faint) = weaker pivots -> internal structure / detail.
//   Each tier is independent (strength + on/off) with HH / HL / LH / LL structure labels and a
//   zig-zag. NON-REPAINTING: a swing prints only once its pivot is CONFIRMED on the structure TF
//   (len bars each side, lookahead off), placed back on the exact bar it formed via the HTF pivot
//   time (gap / DST safe).
indicator("Swing OTE - MTF Swing Points", "Swing OTE", overlay = true, max_lines_count = 500, max_labels_count = 500)

// ========================= structure =========================
structTF = input.timeframe("60", "Structure timeframe", tooltip = "Timeframe the swings are detected on. Blank = chart TF. Trade an LTF chart and set this to your HTF (15 / 60 / 240) to read higher structure. Keep it >= the chart TF.")

grpM = "Major swings (impulse anchors)"
showMajor = input.bool(true, "Show major swings", group = grpM)
majorLen  = input.int(20, "Major swing strength", minval = 1, group = grpM, tooltip = "Left/right bars for a confirmed MAJOR pivot on the structure TF. Higher = fewer, more significant swings. These are the points you anchor an OTE leg to.")
majZig    = input.bool(true, "Major zig-zag", group = grpM)

grpN = "Minor swings (detail)"
showMinor = input.bool(true, "Show minor swings", group = grpN)
minorLen  = input.int(5, "Minor swing strength", minval = 1, group = grpN, tooltip = "Left/right bars for a confirmed MINOR pivot. Internal structure between the major swings. Turn off for a clean major-only view.")
minZig    = input.bool(true, "Minor zig-zag", group = grpN)

grpV = "Labels"
showStruct = input.bool(true, "Label structure (HH / HL / LH / LL)", group = grpV, tooltip = "Off = plain H / L markers.")
showInfo   = input.bool(true, "Info table (TF / last swings)", group = grpV)

grpC = "Colors"
colH = input.color(color.red,   "Swing high", group = grpC)
colL = input.color(color.green, "Swing low", group = grpC)
colZ = input.color(color.gray,  "Zig-zag", group = grpC)

// ========================= MTF pivots (non-repainting) =========================
tf = structTF == "" ? timeframe.period : structTF

// MAJOR pivot value + the actual bar time it formed on (time[len] on the structure TF)
[Mph, MphT] = request.security(syminfo.tickerid, tf, [ta.pivothigh(majorLen, majorLen), time[majorLen]], lookahead = barmerge.lookahead_off, gaps = barmerge.gaps_off)
[Mpl, MplT] = request.security(syminfo.tickerid, tf, [ta.pivotlow(majorLen, majorLen),  time[majorLen]], lookahead = barmerge.lookahead_off, gaps = barmerge.gaps_off)
// MINOR pivots
[mph, mphT] = request.security(syminfo.tickerid, tf, [ta.pivothigh(minorLen, minorLen), time[minorLen]], lookahead = barmerge.lookahead_off, gaps = barmerge.gaps_off)
[mpl, mplT] = request.security(syminfo.tickerid, tf, [ta.pivotlow(minorLen, minorLen),  time[minorLen]], lookahead = barmerge.lookahead_off, gaps = barmerge.gaps_off)

newMajH = not na(Mph) and (na(Mph[1]) or Mph != Mph[1])
newMajL = not na(Mpl) and (na(Mpl[1]) or Mpl != Mpl[1])
newMinH = not na(mph) and (na(mph[1]) or mph != mph[1])
newMinL = not na(mpl) and (na(mpl[1]) or mpl != mpl[1])

// ========================= state =========================
var float majLastH = na
var float majLastL = na
var float minLastH = na
var float minLastL = na
var float zMajP = na
var int   zMajT = na
var float zMinP = na
var int   zMinT = na
var string majLastType = na
var string minLastType = na
var bool   majLastHigh = false
var bool   minLastHigh = false
var table  infoTbl = na

// ========================= MAJOR swings =========================
if showMajor and newMajH
    isHH = na(majLastH) or Mph > majLastH
    txt = showStruct ? (isHH ? "HH" : "LH") : "H"
    majLastType := txt
    majLastHigh := true
    label.new(MphT, Mph, txt, xloc = xloc.bar_time, yloc = yloc.price, style = label.style_label_down, color = color.new(colH, 35), textcolor = color.white, size = size.normal)
    if majZig and not na(zMajP)
        line.new(zMajT, zMajP, MphT, Mph, xloc = xloc.bar_time, color = color.new(colZ, 0), width = 2)
    zMajP := Mph
    zMajT := MphT
    majLastH := Mph

if showMajor and newMajL
    isLL = na(majLastL) or Mpl < majLastL
    txt = showStruct ? (isLL ? "LL" : "HL") : "L"
    majLastType := txt
    majLastHigh := false
    label.new(MplT, Mpl, txt, xloc = xloc.bar_time, yloc = yloc.price, style = label.style_label_up, color = color.new(colL, 35), textcolor = color.white, size = size.normal)
    if majZig and not na(zMajP)
        line.new(zMajT, zMajP, MplT, Mpl, xloc = xloc.bar_time, color = color.new(colZ, 0), width = 2)
    zMajP := Mpl
    zMajT := MplT
    majLastL := Mpl

// ========================= MINOR swings =========================
if showMinor and newMinH
    isHH = na(minLastH) or mph > minLastH
    txt = showStruct ? (isHH ? "hh" : "lh") : "h"
    minLastType := txt
    minLastHigh := true
    label.new(mphT, mph, txt, xloc = xloc.bar_time, yloc = yloc.price, style = label.style_label_down, color = color.new(colH, 80), textcolor = color.new(colH, 0), size = size.tiny)
    if minZig and not na(zMinP)
        line.new(zMinT, zMinP, mphT, mph, xloc = xloc.bar_time, color = color.new(colZ, 45), width = 1, style = line.style_dashed)
    zMinP := mph
    zMinT := mphT
    minLastH := mph

if showMinor and newMinL
    isLL = na(minLastL) or mpl < minLastL
    txt = showStruct ? (isLL ? "ll" : "hl") : "l"
    minLastType := txt
    minLastHigh := false
    label.new(mplT, mpl, txt, xloc = xloc.bar_time, yloc = yloc.price, style = label.style_label_up, color = color.new(colL, 80), textcolor = color.new(colL, 0), size = size.tiny)
    if minZig and not na(zMinP)
        line.new(zMinT, zMinP, mplT, mpl, xloc = xloc.bar_time, color = color.new(colZ, 45), width = 1, style = line.style_dashed)
    zMinP := mpl
    zMinT := mplT
    minLastL := mpl

// ========================= info table =========================
if showInfo and barstate.islast
    if na(infoTbl)
        infoTbl := table.new(position.bottom_right, 2, 3, border_width = 1, frame_width = 1, frame_color = color.new(color.gray, 60))
    tfTxt = str.tostring(timeframe.in_seconds(tf) / 60) + "m"
    majCol = na(majLastType) ? color.gray : (majLastHigh ? colH : colL)
    minCol = na(minLastType) ? color.gray : (minLastHigh ? colH : colL)
    table.cell(infoTbl, 0, 0, "Structure TF", text_color = color.gray, text_size = size.small, text_halign = text.align_left)
    table.cell(infoTbl, 1, 0, tfTxt, text_color = color.white, text_size = size.small, text_halign = text.align_right)
    table.cell(infoTbl, 0, 1, "Last major", text_color = color.gray, text_size = size.small, text_halign = text.align_left)
    table.cell(infoTbl, 1, 1, na(majLastType) ? "-" : majLastType, text_color = majCol, text_size = size.small, text_halign = text.align_right)
    table.cell(infoTbl, 0, 2, "Last minor", text_color = color.gray, text_size = size.small, text_halign = text.align_left)
    table.cell(infoTbl, 1, 2, na(minLastType) ? "-" : minLastType, text_color = minCol, text_size = size.small, text_halign = text.align_right)

// ========================= alerts =========================
alertcondition(newMajH, "Major swing high", "Major structure swing high confirmed")
alertcondition(newMajL, "Major swing low", "Major structure swing low confirmed")
