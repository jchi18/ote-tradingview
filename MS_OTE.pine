//@version=6
// Market Structure + OTE - Trend-Pullback Scanner
//   Low-timeframe MARKET STRUCTURE SHIFT paired with the ICT Optimal Trade Entry zone.
//   This is a TREND-CONTINUATION pullback model (NOT a reversal), shaped by a real-NQ backtest
//   that overturned the textbook "smart-money" version of this setup:
//       1) HTF TREND BIAS (1H EMA50/100 stack) - REQUIRED. The edge only exists with the trend.
//       2) MARKET STRUCTURE SHIFT - on the trading TF, price CLOSES through the most recent
//          confirmed swing high (long) / low (short). That break defines the impulse leg:
//          origin = the swing low/high it came from, extreme = the high/low into the break.
//       3) OTE PULLBACK - draw the fib (0.62 / 0.705 / 0.79) of that leg and enter on the
//          retrace into the zone. Entry defaults to the DEEP 0.79 level (backtest-best, and the
//          only level where SHORTS also work), stop just beyond the leg origin, run to R:R 2.5.
//
//   WHAT THE BACKTEST SAID (real NQ=F 5m, out-of-sample halves + long/short split, 0.02R cost):
//     - Trend-gated MSS+OTE = PF 1.66 / +0.40R expectancy / 41% win, BOTH halves positive
//       (H1 1.98 / H2 1.43) and BOTH directions positive (long 1.64 / short 1.70).
//     - REQUIRING A LIQUIDITY SWEEP (the classic sweep->MSS->OTE sequence) LOSES (PF 0.82) and
//       is left OFF by default; it is offered only as an optional confluence/marker.
//     - Deep 0.79 entry > standard 0.705 (esp. for shorts); higher R:R (2.5-3.0) is better - this
//       is a runner model. Tight 15-bar pullback window beats stale ones.
//   It is a genuine THIRD edge, weaker than VWAP-pullback (PF 2.6) and Sweep/IFVG (PF 3.3) but
//   COMPLEMENTARY: those are mean-reversion/reversal; this fires on trend-day pullbacks.
//
//   CONFLUENCES, RANKED BY THE BACKTEST (not by lore):
//     - FVG inside the OTE zone = the A+ driver. WITH it PF 1.88 / +0.50R; WITHOUT it PF 0.93.
//     - Order Block inside the OTE zone = also helps (PF 1.74) -> A+ when either is present.
//     - Rejection Block = did NOT help (PF 1.25, H2 negative) -> excluded.
//     - Liquidity sweep at the origin = HURTS this model (sweep setups PF 0.69 vs 1.42 without).
//       A sweep is a REVERSAL cue; this is a CONTINUATION model - the sweep belongs to Sweep/IFVG.
//       It is left as an off-by-default optional marker only. Killzone/ADX likewise optional.
//
//   On a signal it plots Entry / Stop / BE / TP1 / TP2 and a green (buy) / red (sell) dot; HOVER
//   the dot for the full checklist. TP1 = first partial, then stop trails to break-even; TP2 = final.
//   Tuned for low NQ/MNQ timeframes (1m-15m). Discretionary scanner - backtest before live size.
indicator("Market Structure + OTE", "MS+OTE", overlay = true, max_lines_count = 60, max_labels_count = 500, max_boxes_count = 30)

// ========================= inputs =========================
grpT = "Step 1 - HTF trend bias (required)"
reqTrend  = input.bool(true, "REQUIRE HTF trend alignment", group = grpT, tooltip = "ON (recommended) = only longs in an uptrend, shorts in a downtrend. The backtested edge depends on this; OFF loses.")
htfRes    = input.timeframe("60", "Trend timeframe", group = grpT, tooltip = "Timeframe the EMA stack is read from. 60 = 1H.")
emaFastLen= input.int(50,  "Fast EMA", minval = 1, group = grpT)
emaSlowLen= input.int(100, "Slow EMA", minval = 1, group = grpT, tooltip = "Bias is UP when price>fast>slow and fast is rising; mirror for DOWN.")

grpM = "Step 2 - Market structure"
piv      = input.int(4, "Swing pivot strength (bars each side)", minval = 2, maxval = 10, group = grpM, tooltip = "Left/right bars for a confirmed swing high/low. 4 was the backtest sweet spot on 5m; raise it on faster TFs (more bars per swing), lower it on slower TFs.")
maxWait  = input.int(15, "Pullback must arrive within N bars of the MSS", minval = 2, group = grpM, tooltip = "Bars after the structure break to wait for the OTE retrace. Fresh pullbacks (15) beat stale ones in the backtest.")

grpO = "Step 3 - OTE entry"
oteFib   = input.float(0.79, "OTE entry level", options = [0.62, 0.705, 0.79], group = grpO, tooltip = "Fib retracement of the impulse leg used as the limit entry. 0.79 = deep (backtest-best, the only level where shorts also work). 0.705 = classic sweet spot. 0.62 = shallow.")
showZone = input.bool(true, "Draw the OTE zone (0.62-0.79)", group = grpO)

grpR = "Risk & targets"
atrLen   = input.int(14, "ATR length", minval = 1, group = grpR)
stopBuf  = input.float(0.15, "Stop buffer beyond leg origin (ATR x)", minval = 0.0, step = 0.05, group = grpR, tooltip = "Pad below the leg low (long) / above the leg high (short) for the stop. Tighter backtests better (0.0 best in-sample) but keep ~0.15 for live fast-TF noise; do not go to 0 live.")
useMinRR = input.bool(true, "Filter out setups below a minimum R:R", group = grpR)
minRR    = input.float(2.0, "Minimum R:R", minval = 0.5, step = 0.25, group = grpR)
tp2Mode  = input.string("Fixed R:R", "TP2 (final) mode", options = ["Fixed R:R", "Liquidity target"], group = grpR, tooltip = "Fixed R:R 2.5 was the validated default (this is a runner model). Liquidity = opposing swing extreme.")
targetRR = input.float(2.5, "TP2 fixed R:R (Fixed mode)", minval = 0.5, step = 0.25, group = grpR)
targetLook= input.int(40, "Opposing-liquidity lookback (Liquidity mode)", minval = 2, group = grpR)
tp1RR    = input.float(1.0, "TP1 R:R (first partial)", minval = 0.25, step = 0.25, group = grpR)
moveBE   = input.bool(true, "Move stop to break-even after TP1", group = grpR)

grpD = "PD array confluence (A+ driver - backtest-validated)"
usePD    = input.bool(true, "Detect FVG / Order Block inside the OTE zone", group = grpD, tooltip = "A Fair Value Gap or Order Block sitting INSIDE the OTE zone is the validated A+ driver. Backtest (real NQ 5m, OOS): setups WITH a PD array in the zone = PF 1.88 / +0.50R; WITHOUT = PF 0.93 / breakeven. (Rejection Blocks did NOT help, so they are excluded.)")
reqPD    = input.bool(false, "REQUIRE an FVG or OB in the OTE zone (top-tier only)", group = grpD, tooltip = "ON = only fire when a PD array is in the zone (A+ only) - roughly halves the signals but ~doubles expectancy. OFF = take all, let the A/A+ grade flag quality.")
rrPremium = input.float(3.0, "R:R premium for a confluence (tooltip info)", minval = 0.5, step = 0.25, group = grpD)
freshBars = input.int(8, "Fresh-pullback window (bars, tooltip info)", minval = 1, group = grpD, tooltip = "An OTE tap within this many bars of the MSS shows as a confluence in the hover checklist.")

grpF = "Optional confluences / filters"
useSweep = input.bool(false, "Mark a liquidity sweep at the leg origin", group = grpF, tooltip = "OFF by default: backtests showed REQUIRING a sweep HURTS this continuation model. Left as a display/confluence only.")
reqSweep = input.bool(false, "...and REQUIRE it (not recommended)", group = grpF)
sweepLook= input.int(20, "Sweep swing lookback (bars)", minval = 2, group = grpF)
reqSess  = input.bool(false, "REQUIRE London/NY killzone", group = grpF)
londonSess= input.session("0200-0500", "London killzone", group = grpF)
nySess    = input.session("0700-1000", "New York killzone", group = grpF)
sessTz    = input.string("America/New_York", "Session timezone", group = grpF)
reqChop  = input.bool(false, "REQUIRE no-chop (ADX)", group = grpF)
adxLen   = input.int(14, "ADX length", minval = 1, group = grpF)
adxSmooth= input.int(14, "ADX smoothing", minval = 1, group = grpF)
adxMin   = input.float(20, "Minimum ADX (not choppy)", minval = 0, step = 1, group = grpF)

grpP = "Position size"
acct     = input.float(50000, "Account ($)", minval = 0, group = grpP)
riskPct  = input.float(1.0, "Risk per trade (%)", minval = 0.1, step = 0.1, group = grpP)
pointVal = input.float(2.0, "$ per point (MNQ=2, NQ=20, MES=5, ES=50)", minval = 0.01, group = grpP)

grpS = "Show"
showDot   = input.bool(true, "Signal dot (green=buy, red=sell)", group = grpS)
showGrade = input.bool(true, "Grade label (A / A+)", group = grpS)
showLines = input.bool(true, "Entry/Stop/BE/TP1/TP2 lines (latest signal)", group = grpS)
showStruct= input.bool(true, "Mark the MSS break", group = grpS)
showPanel = input.bool(true, "Info panel", group = grpS)

// ========================= core series =========================
atr    = ta.atr(atrLen)
newDay = timeframe.change("D")

[diPlus, diMinus, adxVal] = ta.dmi(adxLen, adxSmooth)
notChop = adxVal >= adxMin

emaFast = request.security(syminfo.tickerid, htfRes, ta.ema(close, emaFastLen), barmerge.gaps_off, barmerge.lookahead_off)
emaSlow = request.security(syminfo.tickerid, htfRes, ta.ema(close, emaSlowLen), barmerge.gaps_off, barmerge.lookahead_off)
strongUp = close > emaFast and emaFast > emaSlow and emaFast > emaFast[10]
strongDn = close < emaFast and emaFast < emaSlow and emaFast < emaFast[10]

inLondon = not na(time(timeframe.period, londonSess, sessTz))
inNY     = not na(time(timeframe.period, nySess, sessTz))
inKZ     = inLondon or inNY

// ========================= market structure =========================
ph = ta.pivothigh(high, piv, piv)
pl = ta.pivotlow(low, piv, piv)

var float lastSH = na
var float lastSL = na
var float prevSH = na
var float prevSL = na
var int   lastSHbar = na
var int   lastSLbar = na
var float runHigh = na          // running high since the last confirmed swing low (long leg extreme)
var float runLow  = na          // running low  since the last confirmed swing high (short leg extreme)
var int   usedSHbar = -100000
var int   usedSLbar = -100000

// extend the running leg extremes each bar
if not na(runHigh)
    runHigh := math.max(runHigh, high)
if not na(runLow)
    runLow := math.min(runLow, low)

// register newly-confirmed pivots (known piv bars after the fact)
if not na(ph)
    prevSH := lastSH
    lastSH := ph
    lastSHbar := bar_index - piv
    runLow := ta.lowest(low, piv + 1)
if not na(pl)
    prevSL := lastSL
    lastSL := pl
    lastSLbar := bar_index - piv
    runHigh := ta.highest(high, piv + 1)

// sweep context (origin low/high ran prior liquidity) - optional confluence only
prevLL = ta.lowest(low, sweepLook)[1]
prevHH = ta.highest(high, sweepLook)[1]

// ========================= armed-setup state =========================
var bool  armLong = false
var bool  armShort = false
var float aEntry = na
var float aTop = na
var float aBot = na
var float aLegLow = na
var float aLegHigh = na
var int   aBorn = na
var bool  aSwept = false
var bool  aFVG = false
var bool  aOB = false
var box   oteBox = na
var bool  mssUpEvt = false
var bool  mssDnEvt = false

// active trade (for level-line drawing)
var bool  inTrade = false
var int   tdir = 0
var float tEntry = na
var float tStop = na
var float tTP1 = na
var float tTP2 = na
var bool  tp1done = false
var line  lnE = na
var line  lnS = na
var line  lnT1 = na
var line  lnT2 = na
var label lblE = na
var label lblS = na
var label lblT1 = na
var label lblT2 = na

// panel + exit flags
var string lastTxt = "-"
var string lastGrade = "-"
be_now = false
tp2_now = false
stop_now = false

mssUpEvt := false
mssDnEvt := false

if newDay
    armLong := false
    armShort := false

// ---- A) manage the open trade (exits / BE / extend lines) ----
if inTrade
    if showLines
        line.set_x2(lnE, bar_index)
        line.set_x2(lnS, bar_index)
        line.set_x2(lnT1, bar_index)
        line.set_x2(lnT2, bar_index)
        label.set_x(lblE, bar_index)
        label.set_x(lblS, bar_index)
        label.set_x(lblT1, bar_index)
        label.set_x(lblT2, bar_index)
    if tdir == 1
        if moveBE and not tp1done and high >= tTP1
            tp1done := true
            tStop := tEntry
            be_now := true
            if showLines
                line.set_y1(lnS, tEntry)
                line.set_y2(lnS, tEntry)
                line.set_color(lnS, color.blue)
                label.set_y(lblS, tEntry)
                label.set_text(lblS, "BE")
                label.set_textcolor(lblS, color.blue)
        if low <= tStop
            inTrade := false
            stop_now := true
        else if high >= tTP2
            inTrade := false
            tp2_now := true
    else if tdir == -1
        if moveBE and not tp1done and low <= tTP1
            tp1done := true
            tStop := tEntry
            be_now := true
            if showLines
                line.set_y1(lnS, tEntry)
                line.set_y2(lnS, tEntry)
                line.set_color(lnS, color.blue)
                label.set_y(lblS, tEntry)
                label.set_text(lblS, "BE")
                label.set_textcolor(lblS, color.blue)
        if high >= tStop
            inTrade := false
            stop_now := true
        else if low <= tTP2
            inTrade := false
            tp2_now := true

// ---- B) detect MSS and arm an OTE setup ----
// scan the impulse leg for a PD array (FVG / OB) overlapping the OTE zone [zlo, zhi]
f_pd(legLen, zlo, zhi, bull) =>
    fv = false
    ob = false
    ms = int(math.min(legLen, 120))
    for b = 0 to ms
        if bull
            if low[b] > high[b + 2] and low[b] >= zlo and high[b + 2] <= zhi
                fv := true
            if close[b] < open[b] and math.min(open[b], close[b]) <= zhi and math.max(open[b], close[b]) >= zlo
                ob := true
        else
            if high[b] < low[b + 2] and high[b] <= zhi and low[b + 2] >= zlo
                fv := true
            if close[b] > open[b] and math.min(open[b], close[b]) <= zhi and math.max(open[b], close[b]) >= zlo
                ob := true
    [fv, ob]

trendUpOk = not reqTrend or strongUp
trendDnOk = not reqTrend or strongDn

// LONG: bullish break of the most recent swing high
if not na(lastSH) and not na(lastSL) and not na(lastSHbar) and not na(lastSLbar) and atr > 0
    if close > lastSH and lastSHbar != usedSHbar and lastSL < lastSH and lastSLbar < bar_index and trendUpOk
        legLow = lastSL
        legHigh = math.max(na(runHigh) ? high : runHigh, high)
        rng = legHigh - legLow
        swept = not na(prevLL) and legLow < prevLL
        if rng > 0 and (not reqSweep or swept)
            armLong := true
            armShort := false
            aEntry := legHigh - oteFib * rng
            aTop := legHigh - 0.62 * rng
            aBot := legHigh - 0.79 * rng
            aLegLow := legLow
            aLegHigh := legHigh
            aBorn := bar_index
            aSwept := swept
            [fvL, obL] = f_pd(bar_index - lastSLbar, aBot, aTop, true)
            aFVG := usePD and fvL
            aOB := usePD and obL
            usedSHbar := lastSHbar
            mssUpEvt := true
            if showZone
                if not na(oteBox)
                    box.delete(oteBox)
                oteBox := box.new(bar_index, aTop, bar_index + maxWait, aBot, border_color = color.new(color.teal, 50), bgcolor = color.new(color.teal, 90))

// SHORT: bearish break of the most recent swing low
if not na(lastSH) and not na(lastSL) and not na(lastSHbar) and not na(lastSLbar) and atr > 0 and not mssUpEvt
    if close < lastSL and lastSLbar != usedSLbar and lastSH > lastSL and lastSHbar < bar_index and trendDnOk
        legHigh = lastSH
        legLow = math.min(na(runLow) ? low : runLow, low)
        rng = legHigh - legLow
        swept = not na(prevHH) and legHigh > prevHH
        if rng > 0 and (not reqSweep or swept)
            armShort := true
            armLong := false
            aEntry := legLow + oteFib * rng
            aTop := legLow + 0.79 * rng
            aBot := legLow + 0.62 * rng
            aLegLow := legLow
            aLegHigh := legHigh
            aBorn := bar_index
            aSwept := swept
            [fvS, obS] = f_pd(bar_index - lastSHbar, aBot, aTop, false)
            aFVG := usePD and fvS
            aOB := usePD and obS
            usedSLbar := lastSLbar
            mssDnEvt := true
            if showZone
                if not na(oteBox)
                    box.delete(oteBox)
                oteBox := box.new(bar_index, aTop, bar_index + maxWait, aBot, border_color = color.new(color.maroon, 50), bgcolor = color.new(color.maroon, 90))

if showStruct and (mssUpEvt or mssDnEvt)
    label.new(bar_index, mssUpEvt ? high : low, "MSS", style = mssUpEvt ? label.style_triangleup : label.style_triangledown, color = color.new(mssUpEvt ? color.teal : color.maroon, 30), textcolor = color.gray, size = size.tiny, yloc = mssUpEvt ? yloc.belowbar : yloc.abovebar)

// expire / invalidate armed setups
if armLong and (bar_index - aBorn > maxWait or close < aLegLow)
    armLong := false
if armShort and (bar_index - aBorn > maxWait or close > aLegHigh)
    armShort := false

// ========================= helpers =========================
f_qty(entry, stop) =>
    rp = math.abs(entry - stop)
    rp > 0 and pointVal > 0 ? math.floor((acct * riskPct / 100.0) / (rp * pointVal)) : na
f_chk(b) => b ? "[x] " : "[  ] "

// ========================= entry trigger -> grade -> fire =========================
longFire = false
shortFire = false
var float fE = na
var float fS = na
var float fT1 = na
var float fT2 = na
var float fRR = na
var int   fDir = 0
var string fGrade = "A"
var string fTip = ""

// LONG: pullback taps the OTE entry level
if armLong and not inTrade and atr > 0 and bar_index > aBorn and low <= aEntry
    e = aEntry
    s = aLegLow - stopBuf * atr
    risk = e - s
    if risk > 0
        liq = ta.highest(high, targetLook)
        t2 = tp2Mode == "Liquidity target" ? liq : e + targetRR * risk
        rrv = (t2 - e) / risk
        if t2 > e and (not useMinRR or rrv >= minRR)
            cRR = rrv >= rrPremium
            cSess = inKZ
            cChop = notChop
            cFresh = (bar_index - aBorn) <= freshBars
            cPD = aFVG or aOB
            passReq = (not reqSess or inKZ) and (not reqChop or notChop) and (not reqPD or cPD)
            if passReq
                grade = cPD ? "A+" : "A"
                q = f_qty(e, s)
                longFire := true
                fDir := 1
                fE := e
                fS := s
                fT1 := e + tp1RR * risk
                fT2 := t2
                fRR := rrv
                fGrade := grade
                fTip := "GRADE " + grade + "  (BUY)\n" + f_chk(true) + "HTF trend up\n" + f_chk(true) + "MSS break of structure\n" + f_chk(true) + "OTE pullback (" + str.tostring(oteFib) + ")\n" + f_chk(aFVG) + "FVG in OTE zone\n" + f_chk(aOB) + "Order block in OTE zone\n" + f_chk(cFresh) + "Fresh pullback\n" + f_chk(useSweep and aSwept) + "Liquidity sweep at origin\n" + f_chk(cSess) + "Killzone session\n" + f_chk(cChop) + "No chop (ADX)\n" + f_chk(cRR) + "R:R >= " + str.tostring(rrPremium, "#.##") + "\n----\nEntry " + str.tostring(e, format.mintick) + "\nStop  " + str.tostring(s, format.mintick) + "\nTP1   " + str.tostring(fT1, format.mintick) + "\nTP2   " + str.tostring(t2, format.mintick) + "\nR:R   " + str.tostring(rrv, "#.##") + "   Size ~" + str.tostring(na(q) ? 0 : q) + "c"
                armLong := false

// SHORT: pullback taps the OTE entry level
if armShort and not inTrade and not longFire and atr > 0 and bar_index > aBorn and high >= aEntry
    e = aEntry
    s = aLegHigh + stopBuf * atr
    risk = s - e
    if risk > 0
        liq = ta.lowest(low, targetLook)
        t2 = tp2Mode == "Liquidity target" ? liq : e - targetRR * risk
        rrv = (e - t2) / risk
        if t2 < e and (not useMinRR or rrv >= minRR)
            cRR = rrv >= rrPremium
            cSess = inKZ
            cChop = notChop
            cFresh = (bar_index - aBorn) <= freshBars
            cPD = aFVG or aOB
            passReq = (not reqSess or inKZ) and (not reqChop or notChop) and (not reqPD or cPD)
            if passReq
                grade = cPD ? "A+" : "A"
                q = f_qty(e, s)
                shortFire := true
                fDir := -1
                fE := e
                fS := s
                fT1 := e - tp1RR * risk
                fT2 := t2
                fRR := rrv
                fGrade := grade
                fTip := "GRADE " + grade + "  (SELL)\n" + f_chk(true) + "HTF trend down\n" + f_chk(true) + "MSS break of structure\n" + f_chk(true) + "OTE pullback (" + str.tostring(oteFib) + ")\n" + f_chk(aFVG) + "FVG in OTE zone\n" + f_chk(aOB) + "Order block in OTE zone\n" + f_chk(cFresh) + "Fresh pullback\n" + f_chk(useSweep and aSwept) + "Liquidity sweep at origin\n" + f_chk(cSess) + "Killzone session\n" + f_chk(cChop) + "No chop (ADX)\n" + f_chk(cRR) + "R:R >= " + str.tostring(rrPremium, "#.##") + "\n----\nEntry " + str.tostring(e, format.mintick) + "\nStop  " + str.tostring(s, format.mintick) + "\nTP1   " + str.tostring(fT1, format.mintick) + "\nTP2   " + str.tostring(t2, format.mintick) + "\nR:R   " + str.tostring(rrv, "#.##") + "   Size ~" + str.tostring(na(q) ? 0 : q) + "c"
                armShort := false

// ========================= draw the signal =========================
if longFire or shortFire
    dotCol = fDir == 1 ? color.green : color.red
    gradeCol = fGrade == "A+" ? color.aqua : color.gray
    if showDot
        label.new(bar_index, fE, "", style = label.style_circle, color = dotCol, size = size.tiny, yloc = yloc.price, tooltip = fTip)
    if showGrade
        label.new(bar_index, fE, fGrade, style = fDir == 1 ? label.style_label_up : label.style_label_down, color = color.new(color.black, 100), textcolor = gradeCol, size = size.small, yloc = yloc.price, tooltip = fTip)
    if showLines
        if not na(lnE)
            line.delete(lnE)
            line.delete(lnS)
            line.delete(lnT1)
            line.delete(lnT2)
            label.delete(lblE)
            label.delete(lblS)
            label.delete(lblT1)
            label.delete(lblT2)
        colTp = color.new(color.green, 0)
        lnE  := line.new(bar_index, fE,  bar_index + 1, fE,  color = color.gray, width = 1)
        lnS  := line.new(bar_index, fS,  bar_index + 1, fS,  color = color.red,  width = 1)
        lnT1 := line.new(bar_index, fT1, bar_index + 1, fT1, color = colTp, width = 1, style = line.style_dashed)
        lnT2 := line.new(bar_index, fT2, bar_index + 1, fT2, color = color.new(color.green, 20), width = 2)
        lblE  := label.new(bar_index, fE,  "Entry " + str.tostring(fE, format.mintick), style = label.style_label_left, color = color.new(color.gray, 100), textcolor = color.gray, size = size.small)
        lblS  := label.new(bar_index, fS,  "SL", style = label.style_label_left, color = color.new(color.gray, 100), textcolor = color.red, size = size.small)
        lblT1 := label.new(bar_index, fT1, "TP1", style = label.style_label_left, color = color.new(color.gray, 100), textcolor = colTp, size = size.small)
        lblT2 := label.new(bar_index, fT2, "TP2  R:R " + str.tostring(fRR, "#.##"), style = label.style_label_left, color = color.new(color.gray, 100), textcolor = color.green, size = size.small)
    inTrade := true
    tdir := fDir
    tEntry := fE
    tStop := fS
    tTP1 := fT1
    tTP2 := fT2
    tp1done := false
    lastGrade := fGrade
    q2 = f_qty(fE, fS)
    lastTxt := (fDir == 1 ? "BUY @ " : "SELL @ ") + str.tostring(fE, format.mintick) + "  R:R " + str.tostring(fRR, "#.##") + "  ~" + str.tostring(na(q2) ? 0 : q2) + "c"

// ========================= info panel =========================
var table pan = table.new(position.top_right, 2, 6, border_width = 1)
if showPanel and barstate.islast
    bias = strongUp ? "UP" : (strongDn ? "DOWN" : "mixed")
    armed = armLong ? "long OTE" : (armShort ? "short OTE" : "-")
    table.cell(pan, 0, 0, "MS+OTE", text_size = size.small, text_color = color.white)
    table.cell(pan, 1, 0, inTrade ? "IN TRADE" : "scanning", text_size = size.small, text_color = inTrade ? color.teal : color.gray)
    table.cell(pan, 0, 1, "HTF trend", text_size = size.small, text_color = color.gray)
    table.cell(pan, 1, 1, bias, text_size = size.small, text_color = strongUp ? color.teal : (strongDn ? color.maroon : color.gray))
    table.cell(pan, 0, 2, "ADX", text_size = size.small, text_color = color.gray)
    table.cell(pan, 1, 2, str.tostring(adxVal, "#.#") + (notChop ? "" : " chop"), text_size = size.small, text_color = notChop ? color.white : color.gray)
    table.cell(pan, 0, 3, "Armed OTE", text_size = size.small, text_color = color.gray)
    table.cell(pan, 1, 3, armed, text_size = size.small, text_color = color.white)
    table.cell(pan, 0, 4, "Last grade", text_size = size.small, text_color = color.gray)
    table.cell(pan, 1, 4, lastGrade, text_size = size.small, text_color = lastGrade == "A+" ? color.aqua : color.white)
    table.cell(pan, 0, 5, "Last setup", text_size = size.small, text_color = color.gray)
    table.cell(pan, 1, 5, lastTxt, text_size = size.small, text_color = color.white)

// ========================= alerts =========================
alertcondition(longFire,  "MS+OTE BUY",  "MS+OTE buy - trend + MSS + OTE pullback")
alertcondition(shortFire, "MS+OTE SELL", "MS+OTE sell - trend + MSS + OTE pullback")
alertcondition(longFire or shortFire, "MS+OTE entry", "MS+OTE graded entry signal")
alertcondition(be_now,   "MS+OTE TP1 / BE", "TP1 hit - stop moved to break-even")
alertcondition(tp2_now,  "MS+OTE TP2",      "TP2 hit - final target reached")
alertcondition(stop_now, "MS+OTE stopped",  "Stop hit")
