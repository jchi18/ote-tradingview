//@version=6
// Sweep + IFVG — A+ Reversal Scanner
//   The second validated edge (real NQ=F backtest: base 72.7% win / PF 2.56 over 172 trades;
//   A+ = HTF-stack trend 75% win / PF 2.88). Complements the VWAP Pullback dip-buy — that one
//   is RTH-morning + trend-only and goes quiet often; this one runs 24h on different logic.
//
//   THE MODEL (classic ICT sweep -> displacement -> inverse-FVG entry):
//     LONG  1) a 3-candle BEARISH fair-value gap (gap down: high < low[2]) that price later
//              CLOSES ABOVE flips polarity -> the old gap now acts as SUPPORT (a bullish IFVG).
//           2) (A+) higher-timeframe trend is stacked up; optionally a recent liquidity sweep.
//           3) ENTER on the retrace back into the inverted zone. Stop = zone bottom - 0.25*ATR.
//              Target = RR (default 1.0 = highest win rate; raise for more profit/trade).
//     SHORT = mirror (bullish FVG closed-below -> inverts to resistance).
//
//   Validated config baked in as defaults: 24h, RR1.0, A+ HTF-stack ON. Drop A+ / lower RR to
//   trade more; the base ungated model is still ~73% win.
indicator("Sweep + IFVG — A+ Reversal", "Sweep/IFVG", overlay = true, max_lines_count = 50, max_labels_count = 200, max_boxes_count = 60)

// ───────────────────────── inputs ─────────────────────────
grpS = "Trend bias (higher timeframe)"
htfRes     = input.timeframe("60", "Bias timeframe", group = grpS, tooltip = "60 = 1H.")
emaFastLen = input.int(50,  "Fast EMA", minval = 1, group = grpS)
emaSlowLen = input.int(100, "Slow EMA", minval = 1, group = grpS)

grpI = "Sweep + IFVG"
onlyAplus = input.bool(true, "Only show ★ A+ (HTF-stack trend) signals", group = grpI, tooltip = "ON (default) = only fire when the 1H trend is stacked WITH the reversal (real NQ: 75% win / PF 2.88). OFF = take every IFVG (still ~73% win over a much bigger sample). Note: displacement filtering was tested and HURT it — left out on purpose.")
reqSweep  = input.bool(true, "Require a recent liquidity sweep", group = grpI, tooltip = "ON = the inversion must follow a stop-run beyond a recent swing (true ICT context). Barely changes results but is more faithful to the model.")
sweepLook = input.int(12, "Sweep lookback (bars)", minval = 2, group = grpI, tooltip = "How far back the 'recent swing' for a sweep is measured. 12 = ~1h on 5m.")
sweepWin  = input.int(12, "Sweep must be within (bars)", minval = 1, group = grpI)
zoneLife  = input.int(20, "Inverted zone valid for (bars)", minval = 1, group = grpI, tooltip = "An inverted FVG expires this many bars after it forms if price never retraces into it.")
resetDay  = input.bool(true, "Reset zones each day", group = grpI, tooltip = "Clear tracked gaps at the daily boundary so zones don't bridge across sessions (matches the backtest).")

grpW = "Time window (optional)"
useWindow = input.bool(false, "Only signal inside a time window", group = grpW, tooltip = "OFF (default) = trade 24h, the validated mode. ON = restrict to a session window below.")
winSess   = input.session("0930-1100", "Window", group = grpW)
sessTz    = input.string("America/New_York", "Timezone", group = grpW)

grpR = "Risk / targets"
atrLen  = input.int(14, "ATR length", minval = 1, group = grpR)
stopBuf = input.float(0.25, "Stop buffer beyond zone (ATR ×)", minval = 0.0, step = 0.05, group = grpR)
rr      = input.float(1.0, "Target R:R", minval = 0.25, step = 0.25, group = grpR, tooltip = "1.0 = highest WIN RATE (real NQ A+: 75% win). Raise toward 1.5-2.0 for more profit per trade at a lower hit rate (RR1.5 A+ = 64% / PF 2.61).")

grpP = "Position size"
acct     = input.float(50000, "Account ($)", minval = 0, group = grpP)
riskPct  = input.float(1.0, "Risk per trade (%)", minval = 0.1, step = 0.1, group = grpP)
pointVal = input.float(2.0, "$ per point (MNQ=2, NQ=20, MES=5, ES=50)", minval = 0.01, group = grpP)

grpV = "Show"
showZones = input.bool(true,  "Draw inverted FVG zones", group = grpV)
showSig   = input.bool(true,  "Show BUY/SELL arrows",    group = grpV)
showWhy   = input.bool(true,  "Show confluence checklist", group = grpV)
showPanel = input.bool(true,  "Show info panel",         group = grpV)

// ───────────────────────── core series ─────────────────────────
atr     = ta.atr(atrLen)
newDay  = timeframe.change("D")
inWin   = useWindow ? not na(time(timeframe.period, winSess, sessTz)) : true

emaFast = request.security(syminfo.tickerid, htfRes, ta.ema(close, emaFastLen), barmerge.gaps_off, barmerge.lookahead_off)
emaSlow = request.security(syminfo.tickerid, htfRes, ta.ema(close, emaSlowLen), barmerge.gaps_off, barmerge.lookahead_off)
strongUp = close > emaFast and emaFast > emaSlow and emaFast > emaFast[10]
strongDn = close < emaFast and emaFast < emaSlow and emaFast < emaFast[10]

// liquidity sweep: wick beyond the prior N-bar extreme, close back inside
prevLL = ta.lowest(low, sweepLook)[1]
prevHH = ta.highest(high, sweepLook)[1]
sweptLo = not na(prevLL) and low  < prevLL and close > prevLL
sweptHi = not na(prevHH) and high > prevHH and close < prevHH
var int lastSweepLo = -100000
var int lastSweepHi = -100000
if sweptLo
    lastSweepLo := bar_index
if sweptHi
    lastSweepHi := bar_index

// ───────────────────────── state ─────────────────────────
var float bearTop = na   // latest bearish FVG (gap down) zone
var float bearBot = na
var float bullTop = na   // latest bullish FVG (gap up) zone
var float bullBot = na
var float ibTop = na     // active inverted-bull zone (support)
var float ibBot = na
var int   ibBorn = na
var float isTop = na     // active inverted-bear zone (resistance)
var float isBot = na
var int   isBorn = na
var bool  pLon   = false // pending long
var float pLe = na
var float pLs = na
var float pLt = na
var float pLv = na
var bool  pSon   = false // pending short
var float pSe = na
var float pSs = na
var float pSt = na
var float pSv = na

// trade levels for the most recent fired signal (for panel)
var int   tBar  = na
var int   tDir  = 0
var float tE = na
var float tS = na
var float tT = na

if resetDay and newDay
    bearTop := na
    bearBot := na
    bullTop := na
    bullBot := na
    ibTop := na
    ibBot := na
    isTop := na
    isBot := na
    pLon := false
    pSon := false

// ── 1) fill / cancel existing pending (so a pend armed this bar fires next bar onward) ──
buySig = false
sellSig = false
if pLon
    if close < pLv
        pLon := false
    else if inWin and low <= pLe
        buySig := true
        tBar := bar_index
        tDir := 1
        tE := pLe
        tS := pLs
        tT := pLt
        pLon := false
if pSon
    if close > pSv
        pSon := false
    else if inWin and high >= pSe
        sellSig := true
        tBar := bar_index
        tDir := -1
        tE := pSe
        tS := pSs
        tT := pSt
        pSon := false

// ── 2) inversion: a bearish FVG closed-above flips to bullish IFVG; mirror ──
if not na(bearTop) and close > bearTop
    ibTop := bearTop
    ibBot := bearBot
    ibBorn := bar_index
    bearTop := na
    bearBot := na
if not na(bullBot) and close < bullBot
    isTop := bullTop
    isBot := bullBot
    isBorn := bar_index
    bullTop := na
    bullBot := na
// expire stale zones
if not na(ibBorn) and bar_index - ibBorn > zoneLife
    ibTop := na
    ibBot := na
if not na(isBorn) and bar_index - isBorn > zoneLife
    isTop := na
    isBot := na

// ── 3) arm a pending entry on the bar a zone inverts (A+ + sweep gating) ──
aOkL = not onlyAplus or strongUp
aOkS = not onlyAplus or strongDn
swOkL = not reqSweep or (bar_index - lastSweepLo <= sweepWin)
swOkS = not reqSweep or (bar_index - lastSweepHi <= sweepWin)
if not pLon and not na(ibTop) and ibBorn == bar_index and aOkL and swOkL and atr > 0
    e = ibTop
    s = ibBot - stopBuf * atr
    if e > s
        pLon := true
        pLe := e
        pLs := s
        pLt := e + rr * (e - s)
        pLv := ibBot
if not pSon and not na(isBot) and isBorn == bar_index and aOkS and swOkS and atr > 0
    e = isBot
    s = isTop + stopBuf * atr
    if s > e
        pSon := true
        pSe := e
        pSs := s
        pSt := e - rr * (s - e)
        pSv := isTop

// ── 4) update raw FVG zones at this bar ──
if bar_index >= 2
    if high < low[2]
        bearTop := low[2]
        bearBot := high
    if low > high[2]
        bullTop := low
        bullBot := high[2]

// ───────────────────────── visuals ─────────────────────────
// inverted zones as faint boxes
if showZones and not na(ibTop) and ibBorn == bar_index
    box.new(bar_index, ibTop, bar_index + zoneLife, ibBot, border_color = color.new(color.teal, 40), bgcolor = color.new(color.teal, 88))
if showZones and not na(isTop) and isBorn == bar_index
    box.new(bar_index, isTop, bar_index + zoneLife, isBot, border_color = color.new(color.maroon, 40), bgcolor = color.new(color.maroon, 88))

// position size helper
f_qty(entry, stop) =>
    rp = math.abs(entry - stop)
    rp > 0 and pointVal > 0 ? math.floor((acct * riskPct / 100.0) / (rp * pointVal)) : na

// per-signal "why" tooltip
f_chk(b) => b ? "☑" : "☐"
f_reason(isBuy, e, s, t) =>
    q = f_qty(e, s)
    dir = isBuy ? "BUY (bullish IFVG)" : "SELL (bearish IFVG)"
    str.format("{0}\n{1} HTF-stack trend (★ A+)\n{2} Recent liquidity sweep\n{3} Retrace into inverted FVG\n— — —\nEntry {4}\nStop  {5}\nTarget {6}  (RR {7})\nSize ~{8} contract(s)",
       dir,
       f_chk(isBuy ? strongUp : strongDn),
       f_chk(isBuy ? (not reqSweep or bar_index - lastSweepLo <= sweepWin) : (not reqSweep or bar_index - lastSweepHi <= sweepWin)),
       f_chk(true),
       str.tostring(e, format.mintick), str.tostring(s, format.mintick), str.tostring(t, format.mintick),
       str.tostring(rr), str.tostring(na(q) ? 0 : q))

if showSig and buySig
    label.new(bar_index, low, "BUY", yloc = yloc.belowbar, style = label.style_label_up, color = color.new(color.teal, 0), textcolor = color.white, size = size.small, tooltip = f_reason(true, tE, tS, tT))
if showSig and sellSig
    label.new(bar_index, high, "SELL", yloc = yloc.abovebar, style = label.style_label_down, color = color.new(color.maroon, 0), textcolor = color.white, size = size.small, tooltip = f_reason(false, tE, tS, tT))

// confluence checklist (live)
var table why = table.new(position.bottom_right, 2, 5, border_width = 1)
f_wcell(r, k, ok) =>
    table.cell(why, 0, r, k, text_size = size.small, text_color = color.gray, text_halign = text.align_left)
    table.cell(why, 1, r, f_chk(ok), text_size = size.small, text_color = ok ? color.teal : color.gray)
if showWhy and barstate.islast
    biasUp = strongUp
    biasDn = strongDn
    table.cell(why, 0, 0, "Sweep/IFVG", text_size = size.small, text_color = color.white)
    table.cell(why, 1, 0, biasUp ? "long" : (biasDn ? "short" : "—"), text_size = size.small, text_color = color.white)
    f_wcell(1, "HTF-stack trend ★", biasUp or biasDn)
    f_wcell(2, "Recent sweep", biasUp ? (bar_index - lastSweepLo <= sweepWin) : (bar_index - lastSweepHi <= sweepWin))
    f_wcell(3, "Bull IFVG live", not na(ibTop))
    f_wcell(4, "Bear IFVG live", not na(isTop))

// info panel
var table pan = table.new(position.top_right, 2, 5, border_width = 1)
if showPanel and barstate.islast
    bias = strongUp ? "stacked UP" : (strongDn ? "stacked DN" : "mixed")
    table.cell(pan, 0, 0, "HTF trend", text_size = size.small, text_color = color.gray)
    table.cell(pan, 1, 0, bias, text_size = size.small, text_color = strongUp ? color.teal : (strongDn ? color.maroon : color.gray))
    table.cell(pan, 0, 1, "Bull IFVG", text_size = size.small, text_color = color.gray)
    table.cell(pan, 1, 1, na(ibTop) ? "—" : str.tostring(ibBot, format.mintick) + "–" + str.tostring(ibTop, format.mintick), text_size = size.small, text_color = color.white)
    table.cell(pan, 0, 2, "Bear IFVG", text_size = size.small, text_color = color.gray)
    table.cell(pan, 1, 2, na(isTop) ? "—" : str.tostring(isBot, format.mintick) + "–" + str.tostring(isTop, format.mintick), text_size = size.small, text_color = color.white)
    table.cell(pan, 0, 3, "Last signal", text_size = size.small, text_color = color.gray)
    table.cell(pan, 1, 3, na(tDir) or tDir == 0 ? "—" : (tDir == 1 ? "BUY @ " : "SELL @ ") + str.tostring(tE, format.mintick), text_size = size.small, text_color = color.white)
    table.cell(pan, 0, 4, "Target / Stop", text_size = size.small, text_color = color.gray)
    table.cell(pan, 1, 4, na(tT) ? "—" : str.tostring(tT, format.mintick) + " / " + str.tostring(tS, format.mintick), text_size = size.small, text_color = color.white)

// ───────────────────────── alerts ─────────────────────────
alertcondition(buySig,  "Sweep/IFVG BUY",  "Sweep+IFVG bullish reversal (A+)")
alertcondition(sellSig, "Sweep/IFVG SELL", "Sweep+IFVG bearish reversal (A+)")
alertcondition(buySig or sellSig, "Sweep/IFVG any", "Sweep+IFVG signal")
